# Telegram CLI Bridge example config
# Copy this file to `.env`, then fill in the values you actually use.

# ============ Basic ============

# Telegram bot token from @BotFather.
# Leave empty if you are running in pure Web mode with TELEGRAM_ENABLED=false.
TELEGRAM_BOT_TOKEN=

# Optional: only allow these Telegram user IDs to use the bot.
# Leave empty to allow anyone who can find the bot.
ALLOWED_USER_IDS=

# Main CLI type: codex / claude / kimi
CLI_TYPE=codex

# CLI executable path.
# If the command is already in PATH, keeping `codex` / `claude` / `kimi` is enough.
CLI_PATH=codex

# Default working directory
# Examples:
# WORKING_DIR=C:\path\to\your\project
# WORKING_DIR=/srv/telegram-cli-bridge/project
WORKING_DIR=/srv/telegram-cli-bridge/project


# ============ Runtime Modes ============

# Telegram bot polling
TELEGRAM_ENABLED=true

# Web UI and Web API
WEB_ENABLED=false


# ============ Network ============

# Optional proxy for Telegram API access
# Examples:
# PROXY_URL=http://127.0.0.1:7890
# PROXY_URL=socks5://127.0.0.1:7890
PROXY_URL=


# ============ Web UI ============

WEB_HOST=127.0.0.1
WEB_PORT=8765

# Web login password
WEB_API_TOKEN=change-this-password

# Optional public URL if you already have a reverse proxy or tunnel
WEB_PUBLIC_URL=

# Tunnel mode: disabled / cloudflare_quick
WEB_TUNNEL_MODE=disabled
WEB_TUNNEL_AUTOSTART=true

# Recommended long-term remote access for personal use:
# - keep WEB_TUNNEL_MODE=disabled
# - use Tailscale Serve externally
# - optionally set WEB_PUBLIC_URL=https://your-device.your-tailnet.ts.net
#
# Quick tunnel is only for temporary testing.
# trycloudflare.com quick tunnels do not support SSE, so Web chat streaming is not suitable for production over quick tunnel.
#
# Optional path to cloudflared. Leave empty if `cloudflared` is already in PATH.
# Examples:
# WEB_TUNNEL_CLOUDFLARED_PATH=/usr/bin/cloudflared
# WEB_TUNNEL_CLOUDFLARED_PATH=C:\Tools\cloudflared\cloudflared.exe
WEB_TUNNEL_CLOUDFLARED_PATH=

# If a reverse proxy or a separately managed named tunnel already exposes the service,
# prefer:
# WEB_TUNNEL_MODE=disabled
# WEB_PUBLIC_URL=https://bot.example.com

# Optional CORS allowlist, comma-separated. Usually leave empty unless needed.
WEB_ALLOWED_ORIGINS=


# ============ Assistant Mode Optional ============

# Used by assistant-related flows
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-3-5-sonnet-20241022
ANTHROPIC_BASE_URL=


# ============ Voice Optional ============

WHISPER_ENABLED=true
WHISPER_MODEL=small
WHISPER_LANGUAGE=zh
WHISPER_DEVICE=cpu


# ============ Timeouts ============

# Max time for one CLI task, in seconds
CLI_EXEC_TIMEOUT=4000

# Session idle timeout, in seconds
SESSION_TIMEOUT=3600


# ============ Advanced ============

MANAGED_BOTS_FILE=managed_bots.json
