# Telegram Bot Token (从 @BotFather 获取)
TELEGRAM_BOT_TOKEN=8757607252:AAFvPssswzoeJbFvojFlNuubb3pu1tEs0Y8
TELEGRAM_ENABLED=true

# 允许的用户ID列表（逗号分隔），留空表示允许所有用户
ALLOWED_USER_IDS=5472815837

# CLI 类型: kimi 或 claude
CLI_TYPE=kimi

# CLI 可执行文件路径
CLI_PATH=kimi

# 默认工作目录
WORKING_DIR=C:\Users\JiangKai\telegram_cli_bridge\refactoring

# 代理配置（连接 Telegram API 需要）
# 支持 http/https/socks5 代理，格式: http://host:port 或 socks5://user:pass@host:port
# 也可以设置系统环境变量 HTTPS_PROXY 或 HTTP_PROXY
# PROXY_URL=http://127.0.0.1:7890

# ============ 助手模式配置 ============

# Claude API Key（用于助手模式）
ANTHROPIC_API_KEY=sk-ycHs3L8pXJ3EW949Cuz4Bf6IRSahApCmiiuANcIg5fpsNO7P

# Claude 模型名称
ANTHROPIC_MODEL=claude-opus-4-6

# Claude API Base URL（使用代理商时设置）
# 留空则使用 Anthropic 官方 API
# 例如：ANTHROPIC_BASE_URL=https://api.your-proxy.com/v1
ANTHROPIC_BASE_URL=https://codeflow.asia

# ============ Whisper 语音识别配置 ============

# 是否启用语音识别功能
WHISPER_ENABLED=true

# Whisper 模型大小: tiny/base/small/medium/large
WHISPER_MODEL=small

# 语音识别语言: zh/en/auto
WHISPER_LANGUAGE=zh

# 计算设备: cpu/cuda
WHISPER_DEVICE=cpu

# ============ Web CLI 配置 ============

# ngrok 可执行文件所在目录（留空则使用系统 PATH 中的 ngrok）
# 例如: NGROK_DIR=D:\\Programs\\ngrok-v3-stable-windows-amd64
NGROK_DIR=

# ngrok authtoken（用于 Web CLI 功能，从 https://dashboard.ngrok.com 获取）
# 留空则使用代码中硬编码的 token 或已有的配置文件
NGROK_AUTHTOKEN=

# ============ Web API 配置 ============

# 是否启用内置 Web API（供前端调用）
WEB_ENABLED=false

# Web API 监听地址
WEB_HOST=127.0.0.1
WEB_PORT=8765

# Web API 访问令牌。留空表示不校验，建议生产环境务必设置
WEB_API_TOKEN=change-me

# 允许跨域访问的前端源，多个值用逗号分隔；开发期可用 *
WEB_ALLOWED_ORIGINS=*

# Web 模式默认使用的用户 ID。留空时优先取 ALLOWED_USER_IDS 第一个，否则为 1
WEB_DEFAULT_USER_ID=5472815837
