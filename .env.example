# Web AI CLI Bridge example config
# Copy this file to `.env`, then fill in the values you actually use.

# ============ Basic ============

# Main CLI type: codex / claude
CLI_TYPE=codex

# CLI executable path.
# If the command is already in PATH, keeping `codex` / `claude` is enough.
CLI_PATH=codex

# Model options shown in the chat page model selector.
CLI_MODEL_OPTIONS=gpt-5.5,gpt-5.4,gpt-5.4-mini,gpt-5.3,gpt-5.3-codex,claude-opus-4-7,claude-opus-4-6,claude-sonnet-4-6,none

# Global extra CLI args by CLI type, JSON object.
CLI_GLOBAL_EXTRA_ARGS={}

# Default working directory
# Examples:
# WORKING_DIR=C:\path\to\your\project
# WORKING_DIR=/srv/ai-cli-bridge/project
WORKING_DIR=/srv/ai-cli-bridge/project


# ============ Web ============

WEB_ENABLED=true
WEB_HOST=0.0.0.0
WEB_PORT=8765
WEB_TERMINAL_SHELL_PATH=
TCB_NODE_ID=
WEB_BASE_PATH=

# Web login password
WEB_API_TOKEN=change-this-password

# Optional legacy public URL if you already have a reverse proxy.
WEB_PUBLIC_URL=

# Public exposure modes are mutually exclusive:
# - Cloudflare Quick Tunnel: WEB_TUNNEL_MODE=cloudflare_quick
# - Fixed Hub forward: WEB_FIXED_PUBLIC_FORWARD_ENABLED=true
# For fixed Hub forward, normally set TCB_NODE_ID and WEB_BASE_PATH=/node/<TCB_NODE_ID>.
WEB_FIXED_PUBLIC_FORWARD_ENABLED=false
WEB_FIXED_PUBLIC_FORWARD_URL=
TCB_HUB_FRPS_PORT=
TCB_HUB_NODE_TOKEN=
TCB_HUB_FRPS_TOKEN=
TCB_HUB_FRPC_PATH=
TCB_HUB_FRPC_AUTOSTART=true
WEB_TUNNEL_MODE=disabled
WEB_TUNNEL_AUTOSTART=false

# GitHub Releases repository slug, for example owner/repo.
# Change this only if you publish updates from your own repository.
APP_UPDATE_REPOSITORY=Augustusjk2008/telegram-cli-bot

# Optional path to cloudflared. Leave empty if `cloudflared` is already in PATH.
# Examples:
# WEB_TUNNEL_CLOUDFLARED_PATH=/usr/bin/cloudflared
# WEB_TUNNEL_CLOUDFLARED_PATH=C:\Tools\cloudflared\cloudflared.exe
WEB_TUNNEL_CLOUDFLARED_PATH=

# Optional CORS allowlist, comma-separated. Usually leave empty unless needed.
WEB_ALLOWED_ORIGINS=


# ============ 语言服务 ============

# 语言服务默认关闭；打开文件不会下载任何工具。
TCB_LSP_ENABLED=false

# 显式命令优先于 PATH 与托管工具；留空时自动发现。
TCB_LSP_PYRIGHT_COMMAND=
TCB_LSP_TYPESCRIPT_COMMAND=
TCB_LSP_CLANGD_COMMAND=

# 后续语言服务运行时的安全限制；修改后重启生效。
TCB_LSP_REQUEST_TIMEOUT_SECONDS=10
TCB_LSP_IDLE_TIMEOUT_SECONDS=300
TCB_LSP_MAX_RUNTIMES=8

# 外部依赖源码浏览默认关闭。
TCB_LSP_EXTERNAL_SOURCES_ENABLED=false


# ============ Frontend Build Optional ============

# Preview limits for frontend tool details.
# These VITE_ variables are read at build time. You can also set them in
# front/.env, and values from front/.env take precedence there.
# Leave VITE_BASE_PATH / VITE_API_BASE_URL empty to follow WEB_BASE_PATH at build time.
VITE_BASE_PATH=
VITE_API_BASE_URL=
VITE_CHAT_TRACE_PREVIEW_MAX_LINES=5
VITE_CHAT_TRACE_PREVIEW_MAX_CHARS=200


# ============ Advanced ============

# 原生 agent 无进展看门狗；0 表示禁用。
NATIVE_AGENT_NO_PROGRESS_TIMEOUT_SECONDS=0
MANAGED_BOTS_FILE=managed_bots.json
