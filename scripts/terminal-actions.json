    {
      "id": "restart",
      "label": "重启程序",
      "icon": "Terminal",
      "windowsCommand": "$dataDir = if ($env:TCB_DATA_DIR) { $env:TCB_DATA_DIR } else { Join-Path ([Environment]::GetFolderPath('UserProfile')) '.tcb\\orbit-safe-claw' }; $statePath = Join-Path $dataDir 'web\\runtime_state.json'; $port = if (Test-Path $statePath) { (Get-Content $statePath -Raw | ConvertFrom-Json).actual_port } elseif ($env:WEB_PORT) { $env:WEB_PORT } else { '8765' }; Start-Process -WindowStyle Hidden powershell -ArgumentList @('-NoProfile','-Command',\"try { Invoke-RestMethod -Method Post -Uri 'http://127.0.0.1:$port/api/admin/restart' -TimeoutSec 3 | Out-Null } catch { Write-Error $_ }\")",
      "linuxCommand": "cd /home/ubuntu/telegram-cli-bot-master && TOKEN=$(awk -F= '$1==\"WEB_API_TOKEN\"{print $2}' .env | tr -d '\"'\\'\"'\"' ') && curl -fsS -X POST \"http://127.0.0.1:8765/api/admin/restart\" -H \"Authorization: Bearer $TOKEN\"",
      "macosCommand": "",
      "cwd": ".",
      "confirm": true,
      "enabled": true
    },
