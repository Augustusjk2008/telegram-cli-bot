{
  "schemaVersion": 2,
  "id": "mermaid-visio",
  "name": "Mermaid To Visio",
  "version": "0.1.0",
  "description": "将 Mermaid flowchart 子集导出为可编辑 VSDX。",
  "enabled": true,
  "config": {
    "conversionTimeoutSeconds": 45,
    "graphvizTimeoutSeconds": 8,
    "maxSourceBytes": 1048576,
    "maxDiagramsPerExport": 20,
    "maxNodesPerDiagram": 200,
    "maxEdgesPerDiagram": 400,
    "layoutEngine": "auto",
    "allowSimpleLayoutFallback": true,
    "dotPath": "dot",
    "bundledGraphvizEnabled": true,
    "graphvizRuntimeVersion": "",
    "graphvizRuntimeUrl": "",
    "graphvizRuntimeSha256": ""
  },
  "configSchema": {
    "title": "Mermaid Visio Settings",
    "sections": [
      {
        "id": "limits",
        "title": "转换限制",
        "fields": [
          {
            "key": "conversionTimeoutSeconds",
            "label": "转换超时秒数",
            "type": "integer",
            "default": 45,
            "minimum": 5,
            "maximum": 55,
            "description": "单次插件请求内的转换预算。"
          },
          {
            "key": "graphvizTimeoutSeconds",
            "label": "Graphviz 超时秒数",
            "type": "integer",
            "default": 8,
            "minimum": 1,
            "maximum": 30
          },
          {
            "key": "maxDiagramsPerExport",
            "label": "批量导出最大图数",
            "type": "integer",
            "default": 20,
            "minimum": 1,
            "maximum": 100
          },
          {
            "key": "layoutEngine",
            "label": "布局引擎",
            "type": "select",
            "default": "auto",
            "options": [
              { "value": "auto", "label": "自动" },
              { "value": "graphviz", "label": "Graphviz" },
              { "value": "simple", "label": "简单布局" }
            ]
          },
          {
            "key": "bundledGraphvizEnabled",
            "label": "优先使用插件内 Graphviz",
            "type": "boolean",
            "default": true,
            "description": "启用后优先使用插件 vendor 目录里的 dot.exe。"
          },
          {
            "key": "graphvizRuntimeUrl",
            "label": "Graphviz 运行时下载地址",
            "type": "string",
            "default": "",
            "description": "留空表示不显示安装动作；填入 zip URL 后可从插件页安装。"
          },
          {
            "key": "graphvizRuntimeSha256",
            "label": "Graphviz 运行时 SHA256",
            "type": "string",
            "default": "",
            "description": "必须与下载包匹配，否则拒绝安装。"
          }
        ]
      }
    ]
  },
  "runtime": {
    "type": "python",
    "entry": "backend/main.py",
    "protocol": "jsonrpc-stdio",
    "permissions": {
      "workspaceRead": true,
      "tempArtifacts": true
    }
  },
  "views": [
    {
      "id": "mermaid-visio",
      "title": "Mermaid 转 Visio",
      "renderer": "table",
      "viewMode": "session",
      "dataProfile": "light"
    }
  ],
  "fileHandlers": [
    {
      "id": "markdown-mermaid",
      "label": "Markdown Mermaid 转 Visio",
      "extensions": [".md"],
      "viewId": "mermaid-visio"
    },
    {
      "id": "mermaid-source",
      "label": "Mermaid 转 Visio",
      "extensions": [".mmd", ".mermaid"],
      "viewId": "mermaid-visio"
    }
  ]
}
