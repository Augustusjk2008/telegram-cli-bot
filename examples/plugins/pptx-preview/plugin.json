{
  "schemaVersion": 2,
  "id": "pptx-preview",
  "name": "PPTX Preview",
  "version": "0.1.0",
  "description": "快速浏览 PowerPoint 幻灯片文本、图片、背景和表格。",
  "enabled": true,
  "config": {
    "maxSlides": 80,
    "maxItemsPerSlide": 240
  },
  "runtime": {
    "type": "python",
    "entry": "backend/main.py",
    "protocol": "jsonrpc-stdio",
    "permissions": {
      "workspaceRead": true,
      "tempArtifacts": true
    }
  },
  "views": [
    {
      "id": "document",
      "title": "幻灯片预览",
      "renderer": "document",
      "viewMode": "snapshot",
      "dataProfile": "heavy"
    }
  ],
  "fileHandlers": [
    {
      "id": "pptx-file",
      "label": "PowerPoint 预览",
      "extensions": [
        ".pptx"
      ],
      "viewId": "document"
    }
  ],
  "configSchema": {
    "title": "PPTX 预览设置",
    "sections": [
      {
        "id": "limits",
        "title": "预览限制",
        "fields": [
          {
            "key": "maxSlides",
            "label": "最多幻灯片",
            "type": "integer",
            "default": 80,
            "minimum": 1,
            "maximum": 300,
            "step": 1
          },
          {
            "key": "maxItemsPerSlide",
            "label": "每页最多元素",
            "type": "integer",
            "default": 240,
            "minimum": 20,
            "maximum": 1000,
            "step": 10
          }
        ]
      }
    ]
  }
}
