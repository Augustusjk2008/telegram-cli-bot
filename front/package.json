{
  "name": "web-bot-front",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite --port=3000 --host=0.0.0.0",
    "build": "vite build && node scripts/check-build-budget.mjs",
    "check:build-budget": "node scripts/check-build-budget.mjs",
    "verify:portable-dist": "node scripts/verify-build-assets.mjs",
    "preview": "vite preview",
    "clean": "node -e \"require('fs').rmSync('dist', { recursive: true, force: true })\"",
    "lint": "tsc --noEmit",
    "test:gate": "vitest run --maxWorkers=1 --fileParallelism=false src/test/app.test.tsx src/test/ag-ui-stream-adapter.test.ts src/test/bot-manager-delete.test.tsx src/test/chat-screen.test.tsx src/test/chat-screen-bot-switch-regressions.test.tsx src/test/chat-message-merge.test.ts src/test/git-diff-viewer.test.tsx src/test/git-screen.test.tsx src/test/real-client.test.ts src/test/settings-screen.test.tsx src/test/frame-batched-queue.test.tsx src/test/chat-stream-batch.test.ts src/test/chat-history-sync.test.tsx src/test/history-delta-state.test.ts src/test/dynamic-virtual-list.test.tsx src/test/mermaid-renderer.test.tsx src/test/performance-invariants.test.tsx src/test/terminal-recovery.test.ts src/test/terminal-session.test.ts",
    "test": "vitest run",
    "e2e": "playwright test"
  },
  "dependencies": {
    "@ag-ui/core": "^0.0.55",
    "@codemirror/lang-cpp": "^6.0.3",
    "@codemirror/lang-css": "^6.3.1",
    "@codemirror/lang-html": "^6.4.11",
    "@codemirror/lang-javascript": "^6.2.4",
    "@codemirror/lang-json": "^6.0.2",
    "@codemirror/lang-markdown": "^6.3.4",
    "@codemirror/lang-python": "^6.2.1",
    "@codemirror/language": "^6.12.3",
    "@codemirror/legacy-modes": "^6.5.3",
    "@codemirror/state": "^6.7.1",
    "@codemirror/view": "^6.43.6",
    "@google/genai": "^1.29.0",
    "@tailwindcss/vite": "^4.1.14",
    "@uiw/react-codemirror": "^4.25.2",
    "@vitejs/plugin-react": "^5.0.4",
    "@xterm/addon-attach": "^0.12.0",
    "@xterm/addon-fit": "^0.11.0",
    "@xterm/xterm": "^6.0.0",
    "clsx": "^2.1.1",
    "dotenv": "^17.2.3",
    "express": "^4.21.2",
    "katex": "^0.16.45",
    "lucide-react": "^0.546.0",
    "mermaid": "^11.14.0",
    "motion": "^12.23.24",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-markdown": "^10.1.0",
    "rehype-katex": "^7.0.1",
    "remark-gfm": "^4.0.1",
    "remark-math": "^6.0.0",
    "tailwind-merge": "^3.5.0",
    "vite": "^6.2.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.59.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/express": "^4.17.21",
    "@types/node": "^22.14.0",
    "autoprefixer": "^10.4.21",
    "jsdom": "^29.0.2",
    "tailwindcss": "^4.1.14",
    "tsx": "^4.21.0",
    "typescript": "~5.8.2",
    "vite": "^6.2.0",
    "vitest": "^4.1.3"
  }
